DEEPSEEK_API_KEY=请通过密钥管理服务注入
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

USE_QDRANT_KB=true
KB_TOP_K=3
KB_QDRANT_PATH=/app/app/data/qdrant_store

HF_HOME=/app/.cache/huggingface
TRANSFORMERS_CACHE=/app/.cache/huggingface
XDG_CACHE_HOME=/app/.cache
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

UVICORN_WORKERS=1
REBUILD_KB_ON_START=false
KB_BUILD_TAG=cloud_boot

ADMIN_REVIEW_TOKEN=请通过密钥管理服务注入
NOVEL_CASE_QUEUE_ENABLED=1
NOVEL_CASE_MIN_PROBABILITY=0.72
NOVEL_CASE_MIN_CONFIDENCE=0.45
NOVEL_CASE_MIN_TEXT_LEN=30
NOVEL_CASE_KB_SCORE_THRESHOLD=0.55
